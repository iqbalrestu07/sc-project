# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=ganti_password_ini
DB_NAME=sc_pos
# Port DB yang di-expose ke host lokal (untuk DBeaver, dll). Default 5432.
DB_PORT_EXPOSE=5432

# ─── Backend ──────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=ganti-dengan-string-acak-panjang-minimal-32-karakter

# URL publik backend — dipakai untuk generate URL upload (gambar, dll).
# Gunakan IP LAN saat akses lokal, atau domain Cloudflare saat akses publik.
# Contoh LAN    : http://192.168.1.100:8080
# Contoh publik : https://api.namadomain.com
BACKEND_BASE_URL=http://192.168.1.100:8080

# Port backend yang di-expose ke host. Default 8080.
BACKEND_PORT_EXPOSE=8080

# Organisasi yang digunakan landing page pada root domain (/).
# Landing tenant spesifik tersedia pada /<organization-slug>.
DEFAULT_PUBLIC_ORG_SLUG=

# WhatsApp (opsional — kosongkan jika tidak dipakai)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# ─── Frontend ─────────────────────────────────────────────────────────────────
# URL API yang DIGUNAKAN BROWSER untuk hit backend.
# WAJIB diisi dengan IP LAN atau domain publik — bukan "localhost"
# karena browser di HP/laptop lain tidak tahu "localhost" komputer ini.
#
# Contoh LAN    : http://192.168.1.100:8080/api
# Contoh publik : https://api.namadomain.com/api
#
# PENTING: Setelah mengubah nilai ini, jalankan ulang:
#   docker compose up --build frontend
VITE_API_BASE_URL=http://192.168.1.100:8080/api

# Port frontend yang di-expose ke host. Default 3000.
FRONTEND_PORT_EXPOSE=3000

# ─── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Token tunnel dari dashboard Cloudflare.
# Cara mendapatkannya:
#   1. https://one.dash.cloudflare.com → Networks → Tunnels → Create a tunnel
#   2. Pilih "Cloudflared", beri nama (misal: sc-klinik), klik Next
#   3. Copy token yang ditampilkan di halaman instalasi
#   4. Paste di sini
#
# Setelah itu, di halaman tunnel yang sama → tab "Public Hostname" → Add:
#   Hostname 1: app.namadomain.com  | Service: HTTP | URL: frontend:80
#   Hostname 2: api.namadomain.com  | Service: HTTP | URL: backend:8080
#
# Jika tidak memakai Cloudflare Tunnel, hapus/komentari service "cloudflared"
# di docker-compose.yml dan biarkan variabel ini kosong.
CLOUDFLARE_TUNNEL_TOKEN=
